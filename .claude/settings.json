{
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(find . *)",
      "Bash(uv run *)",
      "Bash(jupyter nbconvert *)",
      "Bash(python *)",
      "Bash(wc -l *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Read(**/__pycache__/**)",
      "Read(**/.venv/**)",
      "Read(/**/*.egg-info/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/pkumari/Documents/Projects/llms-from-scratch/.claude/hooks/suggest-reflect.sh",
            "statusMessage": "Analyzing session for learnings...",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
